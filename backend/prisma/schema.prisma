// Gerador de Cliente
generator client {
  provider = "prisma-client-js"
}

// Fonte de Dados
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- SEUS MODELOS ---
model User {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String?
  password          String?
  phoneNumber       String?   @unique
  provider          String    @default("local") // "local", "google"
  
  emailVerified     DateTime?
  confirmationToken String?   @unique

  posts             Post[]
  postComments      PostComment[]
  resourceComments  ResourceComment[]
}


// --- MODELOS DE PLACEHOLDER (necessários para as relações acima funcionarem) ---
model Post {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  title     String
  content   String?
  
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
}

model PostComment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  text      String
  
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
}

model ResourceComment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  text      String

  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
}
